<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<%- include('partials/navbar', { session: session }) %>

<div class="max-w-6xl mx-auto mt-10 px-4">

  <!-- Welcome -->
  <div class="bg-black text-white p-8 rounded-3xl shadow-xl mb-10">
    <h1 class="text-3xl font-bold">
      Welcome <%= session.userName %> 👋
    </h1>
    <p class="text-gray-300 mt-2">Ready to write something powerful today?</p>

    <a href="/blogs/new"
       class="inline-block mt-5 bg-white text-black px-6 py-3 rounded-xl font-semibold">
       ✍️ Create New Blog
    </a>
  </div>

  <!-- Quick stats -->
  <div class="grid md:grid-cols-3 gap-6">

    <div class="bg-white p-6 rounded-2xl shadow">
      <h2 class="text-gray-500 text-sm">Your Blogs</h2>
      <p class="text-3xl font-bold mt-2"><%= totalBlogs %></p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow">
      <h2 class="text-gray-500 text-sm">Total Reads</h2>
      <p class="text-3xl font-bold mt-2"><%= totalReads %></p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow">
      <h2 class="text-gray-500 text-sm">Account Status</h2>
      <p class="text-2xl font-bold mt-2 text-green-600">Active</p>
    </div>

  </div>

</div>

</body>
</html>
