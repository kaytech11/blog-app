<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Explore Blogs</title>
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Google font -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">

  <style>
    body{font-family:'Inter',sans-serif}
  </style>
</head>

<body class="bg-gradient-to-br from-gray-50 to-gray-200 min-h-screen">

<%- include('../partials/navbar', { session: session }) %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6 sm:mt-10 mb-10 ">

  <!-- HERO -->
  <div class="bg-black text-white rounded-2xl sm:rounded-3xl p-6 sm:p-10 mb-8 sm:mb-12 shadow-2xl">
    
    <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-extrabold mb-3 leading-tight">
      Discover Amazing Stories and Ideas
    </h1>

    <p class="text-gray-300 text-sm sm:text-base md:text-lg">
      Read, write and share powerful ideas with the world.
    </p>

    <% if(session.userId){ %>
      <a href="/blogs/new"
         class="inline-block mt-5 sm:mt-6 bg-white text-black px-5 py-2.5 sm:px-6 sm:py-3 rounded-xl font-semibold hover:bg-gray-200 transition">
         ✍️ Write a Blog
      </a>
    <% } %>
  </div>

  <!-- BLOG GRID -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8 lg:gap-10">

  <% blogs.forEach(blog=> { %>

    <div class="group bg-white rounded-2xl sm:rounded-3xl shadow-lg hover:shadow-2xl transition overflow-hidden border">

      <!-- IMAGE -->
      <div class="relative overflow-hidden">
        <% if (blog.photo) { %>
          <img src="<%= blog.photo %>"
               class="w-full h-44 sm:h-52 md:h-56 object-cover group-hover:scale-110 transition duration-500">
        <% } else { %>
          <div class="w-full h-44 sm:h-52 md:h-56 bg-gradient-to-r from-indigo-500 to-purple-600"></div>
        <% } %>

        <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
      </div>

      <!-- CONTENT -->
      <div class="p-4 sm:p-5 md:p-6">

        <!-- Author -->
        <div class="flex items-center justify-between mb-2 sm:mb-3">
          <p class="text-xs sm:text-sm text-gray-500">
            By
            <% if(blog.author){ %>
              <a href="/blogs/author/<%= blog.author._id %>"
                 class="font-semibold text-black hover:underline">
                 <%= blog.author.name %>
              </a>
            <% } else { %>
              Unknown
            <% } %>
          </p>

          <span class="text-[10px] sm:text-xs bg-gray-100 px-2 sm:px-3 py-1 rounded-full">
            Blog
          </span>
        </div>

        <!-- Title -->
        <h2 class="text-lg sm:text-xl font-bold text-gray-900 leading-snug mb-2 sm:mb-3 group-hover:text-indigo-600 transition">
          <%= blog.title %>
        </h2>

        <!-- Preview -->
        <p class="text-gray-600 text-xs sm:text-sm leading-relaxed mb-4 sm:mb-5">
          <%= blog.content.substring(0, 120) %>...
        </p>

        <!-- Footer -->
        <div class="flex items-center justify-between">

          <a href="/blogs/<%= blog._id %>"
             class="font-semibold text-indigo-600 hover:underline text-sm sm:text-base">
             Read full story →
          </a>

          <% if (session.userId && blog.author && blog.author.equals && blog.author.equals(session.userId)) { %>
            <div class="flex gap-3 text-xs sm:text-sm">
              <a href="/blogs/<%= blog._id %>/edit"
                 class="text-gray-500 hover:text-black font-semibold">
                 Edit
              </a>

              <form method="POST" action="/blogs/<%= blog._id %>?_method=DELETE">
                <button class="text-red-500 hover:text-red-700 font-semibold">
                  Delete
                </button>
              </form>
            </div>
          <% } %>

        </div>

      </div>
    </div>

  <% }) %>

  </div>

</div>

</body>
</html>
