<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>
    <%= blog.title %>
  </title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-gray-50 to-gray-200 min-h-screen font-sans">

  <%- include('../partials/navbar', { session: session }) %>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mt-12 sm:mt-16 mb-16">

      <!-- Blog Card -->
      <div class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-gray-200">

        <!-- SHOW IMAGE -->
        <% if(blog.photo){ %>
          <div class="mb-8 px-6 mt-6 flex justify-center">

            <div class="w-full max-w-3xl overflow-hidden rounded-2xl shadow-lg">

              <img src="<%= blog.photo %>"
                class="w-full h-72 sm:h-80 object-cover transition-transform duration-300 hover:scale-[1.02]">

            </div>

          </div>
          <% } %>

            <!-- SHOW VIDEO -->
            <% if(blog.video){ %>
              <div class="mb-6 px-4">
                <video controls class="w-full rounded-2xl shadow-lg">
                  <source src="<%= blog.video %>" type="video/mp4">
                  Your browser does not support the video tag.
                </video>
              </div>
              <% } %>

                <!-- Blog Content -->
                <div class="p-6 sm:p-8">

                  <!-- Author -->
                  <p class="text-sm text-gray-500 mb-2">
                    By
                    <% if(blog.author){ %>
                      <a href="/blogs/author/<%= blog.author._id %>"
                        class="font-semibold text-gray-900 hover:underline">
                        <%= blog.author.name %>
                      </a>
                      <% } else { %>
                        Unknown
                        <% } %>
                  </p>

                  <!-- Title -->
                  <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-6 tracking-tight">
                    <%= blog.title %>
                  </h1>

                  <!-- Content -->
                  <p class="text-gray-700 leading-relaxed text-base sm:text-lg mb-8">
                    <%= blog.content %>
                  </p>

                  <!-- Actions -->
                  <div class="flex flex-wrap gap-4 items-center mb-6">
                    <% if(session.userId && blog.author && blog.author.equals && blog.author.equals(session.userId)) {
                      %>
                      <a href="/blogs/<%= blog._id %>/edit"
                        class="px-5 py-2 bg-blue-600 text-white rounded-xl font-semibold hover:bg-blue-700 transition">
                        Edit
                      </a>
                      <form method="POST" action="/blogs/<%= blog._id %>?_method=DELETE" class="inline">
                        <button
                          class="px-5 py-2 bg-red-600 text-white rounded-xl font-semibold hover:bg-red-700 transition">
                          Delete
                        </button>
                      </form>
                      <% } %>
                  </div>

                  <a href="/blogs"
                    class="inline-block px-5 py-2 bg-gray-200 text-gray-900 rounded-xl font-semibold hover:bg-gray-300 transition">
                    ← Back to All Blogs
                  </a>

                </div>
      </div>
    </div>

</body>

</html>