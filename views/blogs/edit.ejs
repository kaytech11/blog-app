<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Edit Blog</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">
  <%- include('../partials/navbar', { session: session }) %>

    <div class="max-w-md mx-auto mt-20 bg-white p-8 shadow rounded">
      <h1 class="text-2xl font-bold mb-4">Edit Blog</h1>

      <form action="/blogs/<%= blog._id %>?_method=PUT" method="POST" enctype="multipart/form-data">

        <input type="text" name="title" value="<%= blog.title %>" class="w-full border p-3 mb-4"
          placeholder="Blog title">

        <textarea name="content" class="w-full border p-3 mb-4" rows="6"
          placeholder="Write blog..."><%= blog.content %></textarea>

        <!-- CURRENT IMAGE -->
        <% if(blog.photo){ %>
          <p class="text-sm mb-2 text-gray-500">Current Image:</p>
          <img src="<%= blog.photo %>?v=<%= Date.now() %>" class="w-40 mb-4 rounded shadow">
          <% } %>

            <!-- NEW IMAGE -->
            <input type="file"  name="photo" class="mb-4">

            <button class="bg-blue-600 text-white px-6 py-2 rounded">
              Update Blog
            </button>

      </form>

    </div>

</body>

</html>