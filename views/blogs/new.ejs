<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Create Blog</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">
  <%- include('../partials/navbar', { session: session }) %>

    <div class="max-w-md mx-auto mt-20 bg-white p-8 shadow rounded">
      <h1 class="text-2xl font-bold mb-4">Create New Blog</h1>

      <form method="POST" action="/blogs" enctype="multipart/form-data">

<input name="title" placeholder="Title" class="w-full border p-3 mb-3">
<textarea name="content" placeholder="Write blog..." class="w-full border p-3 mb-3"></textarea>

<!--  IMAGE -->
<label class="font-semibold">Upload Images</label>
<input type="file" name="photo"  class="w-full border p-3 mb-3">

<!-- VIDEO -->
<label class="font-semibold">Upload Video</label>
<input type="file" name="video"  class="w-full border p-3 mb-3">

<button class="bg-black text-white px-6 py-3 rounded">Post Blog</button>
</form>

    </div>

</body>

</html>